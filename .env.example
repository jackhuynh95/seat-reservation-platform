NODE_ENV=development

# Service ports
GATEWAY_PORT=3000
AUTH_SERVICE_PORT=3001
SEAT_SERVICE_PORT=3002
PAYMENT_SERVICE_PORT=3003
PAYMENT_WORKER_PORT=3004

# Public browser/API config
CORS_ORIGINS=http://localhost:5173
RATE_LIMIT_PER_MINUTE=120
COOKIE_SECURE=false

# Local PostgreSQL, aligned with docker-compose.yml
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=seat_reservation
DB_PASSWORD=seat_reservation
DB_DATABASE=seat_reservation
DB_POOL_MAX=10

# Broker
RABBITMQ_URL=amqp://seat_reservation:seat_reservation@localhost:5672

# Service URLs for local dev
AUTH_SERVICE_URL=http://localhost:3001
SEAT_SERVICE_URL=http://localhost:3002
PAYMENT_SERVICE_URL=http://localhost:3003

# Required secrets. Replace before non-local use.
JWT_ACCESS_SECRET=change-me-access-secret-at-least-32-chars
PAYMENT_WEBHOOK_SECRET=change-me-webhook-secret-at-least-32-chars
INTERNAL_SERVICE_TOKEN=change-me-internal-service-token

# Demo account and mock finance settings
DEMO_USER_EMAIL=demo@example.com
DEMO_USER_PASSWORD=Password123!
SEAT_PRICE_CENTS=5000
