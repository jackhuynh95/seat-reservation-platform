{
  "name": "seat-reservation-platform",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -ws --if-present",
    "lint": "eslint \"{apps,packages,tests}/**/*.ts\"",
    "test": "vitest run",
    "test:e2e": "vitest run tests/e2e-happy-path.test.ts",
    "typecheck": "tsc -b",
    "dev:gateway": "npm run dev -w apps/gateway",
    "dev:auth": "npm run dev -w apps/auth-service",
    "dev:seat": "npm run dev -w apps/seat-service",
    "dev:payment": "npm run dev -w apps/payment-service",
    "dev:worker": "npm run dev -w apps/payment-worker",
    "dev:web": "npm run dev -w apps/web"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.20",
    "@nestjs/core": "^10.4.20",
    "@nestjs/platform-express": "^10.4.20",
    "amqplib": "^0.10.8",
    "argon2": "^0.41.1",
    "cookie": "^0.6.0",
    "helmet": "^7.2.0",
    "jose": "^5.10.0",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.7",
    "@types/cookie": "^0.6.0",
    "@types/express": "^4.17.23",
    "@types/node": "^20.19.17",
    "@types/pg": "^8.15.5",
    "@vitejs/plugin-react": "^5.1.2",
    "eslint": "^9.39.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^7.2.7",
    "vitest": "^4.0.16"
  }
}
